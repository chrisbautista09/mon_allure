{% set planName = demoPlan.title ?? 'Marathon -3h' %}
{% set progress = 75 %}

<section
    class="
        mx-4
        mt-5
        rounded-2xl
        border
        border-blue-300/15
        bg-[linear-gradient(145deg,rgba(20,42,91,0.92),rgba(5,12,30,0.82))]
        p-4
        shadow-lg
        backdrop-blur-md
    "
>
    <h2
        class="
            mb-4
            text-xs
            font-black
            tracking-[0.15em]
            text-slate-400
            uppercase
        "
    >
        Plan d'entraînement
    </h2>

    <div class="grid grid-cols-[50px_minmax(0,1fr)_65px] items-center gap-3">
        <div
            class="
                flex
                size-12
                items-center
                justify-center
                rounded-xl
                border
                border-blue-500/70
                bg-blue-700/25
                text-2xl
                text-cyan-300
                shadow-inner
            "
        >
            ⚡
        </div>

        <div class="min-w-0">
            <h3 class="truncate text-lg font-black text-white">
                {{ planName }}
            </h3>

            <p class="mt-1 text-xs text-slate-400">
                Semaine 4 à 12 · 45 km / 60 km
            </p>
        </div>

        <div class="text-right">
            <strong class="text-lg font-black text-cyan-300">
                {{ progress }}%
            </strong>

            <div
                class="
                    mt-2
                    h-1.5
                    w-16
                    overflow-hidden
                    rounded-full
                    bg-slate-500/50
                "
            >
                <div
                    class="
                        h-full
                        rounded-full
                        bg-cyan-300
                        shadow-[0_0_8px_rgba(34,211,238,0.9)]
                    "
                    style="width: {{ progress }}%;"
                ></div>
            </div>
        </div>
    </div>
</section>